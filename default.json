{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    ":automergeAll",
    ":automergeBranch",
    "config:best-practices",
    "github>kachick/renovate-config-dprint#1.3.0",
    "schedule:monthly"
  ],
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "automerge": true,
    "schedule": ["at any time"]
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Bump the hugoh/hk-config Pkl package pin embedded in package:// import URLs",
      "managerFilePatterns": ["/\\.pkl$/"],
      "matchStrings": [
        "package://github\\.com/hugoh/hk-config/releases/download/v[^/]+/hk-config@(?<currentValue>[^#]+)#"
      ],
      "datasourceTemplate": "github-tags",
      "packageNameTemplate": "hugoh/hk-config",
      "extractVersionTemplate": "^v(?<version>.*)$",
      "versioningTemplate": "semver",
      "autoReplaceStringTemplate": "package://github.com/hugoh/hk-config/releases/download/v{{{newValue}}}/hk-config@{{{newValue}}}#"
    }
  ],
  "packageRules": [
    {
      "matchUpdateTypes": ["major"],
      "groupName": "major updates",
      "automerge": false
    },
    {
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "matchManagers": ["!github-actions"],
      "groupName": "non-major updates"
    },
    {
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "groupName": "github actions updates"
    },
    {
      "matchManagers": ["github-actions"],
      "matchPackageNames": ["hugoh/gh-workflows"],
      "schedule": ["at any time"]
    },
    {
      "matchManagers": ["custom.regex"],
      "matchPackageNames": ["hugoh/hk-config"],
      "minimumReleaseAge": null,
      "schedule": ["at any time"]
    }
  ]
}
